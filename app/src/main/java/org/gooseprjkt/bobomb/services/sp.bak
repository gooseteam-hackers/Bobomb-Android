package org.gooseprjkt.bobomb.services

import kotlinx.serialization.json.Json
import okhttp3.*
import okhttp3.MediaType.Companion.toMediaType
import okhttp3.RequestBody.Companion.toRequestBody
import okhttp3.HttpUrl.Companion.toHttpUrlOrNull
import org.gooseprjkt.bobomb.services.core.Callback
import org.gooseprjkt.bobomb.services.core.Phone
import org.gooseprjkt.bobomb.services.core.Service
import java.io.IOException

class ServiceParser {
    companion object {
        private val json = Json {
            ignoreUnknownKeys = true
        }

        fun parseServiceConfig(jsonString: String): ServiceConfig {
            return json.decodeFromString<ServiceConfig>(jsonString)
        }

        fun convertToServices(config: ServiceConfig): List<Service> {
            val services = mutableListOf<Service>()

            for (serviceDef in config.services) {
                when (serviceDef.type.lowercase()) {
                    "sms", "combo" -> {
                        serviceDef.sms_services?.forEach { serviceMap ->
                            serviceMap.forEach { (name, request) ->
                                services.add(createServiceFromRequest(request, name, 7))
                            }
                        }
                    }
                    "call", "combo" -> {
                        serviceDef.call_services?.forEach { serviceMap ->
                            serviceMap.forEach { (name, request) ->
                                services.add(createServiceFromRequest(request, name, 7))
                            }
                        }
                    }
                }
            }

            return services
        }

        private fun createServiceFromRequest(request: ServiceRequest, name: String, vararg countryCodes: Int): Service {
            return object : Service(*countryCodes) {
                override fun run(client: OkHttpClient, callback: Callback, phone: Phone) {
                    // Format URL with phone data
                    var formattedUrl = request.url
                        .replace("{full_phone}", phone.toString())
                        .replace("{phone}", phone.phone)
                        .replace("{country_code}", phone.countryCode.toString())
                        .replace("{random_uuid}", java.util.UUID.randomUUID().toString())
                        .replace("{csrf_token}", "dummy_csrf_token")
                        .replace("{process_uuid}", java.util.UUID.randomUUID().toString())
                        .replace("{phone:+7 (***) ***-**-**}", phone.format("+7 (%1\$s) %2\$s-%3\$s-%4\$s"))
                        .replace("{phone:+7(***)***-**-**}", phone.format("+7%1\$s%2\$s-%3\$s-%4\$s"))
                        .replace("{phone:(***)***-**-**}", phone.format("(%1\$s)%2\$s-%3\$s-%4\$s"))
                        .replace("{phone:+7 *** ***-**-**}", phone.format("+7 %1\$s %2\$s-%3\$s-%4\$s"))
                        .replace("{phone:+7(***)***-****}", phone.format("+7%1\$s%2\$s-%3\$s%4\$s"))
                        .replace("{phone:+7(***)***-**-**}", phone.format("+7%1\$s%2\$s-%3\$s-%4\$s"))
                        .replace("{phone:+7 (***) ***-**-**}", phone.format("+7 (%1\$s) %2\$s-**-**"))
                        .replace("{phone:+7(***) ***-**-**}", phone.format("+7%1\$s ***-**-**"))

                    // Handle query parameters if present
                    var urlWithParams = formattedUrl
                    if (request.params != null) {
                        try {
                            // Parse the URL to add query parameters using extension function
                            val httpUrl = formattedUrl.toHttpUrlOrNull()
                            if (httpUrl != null) {
                                val httpUrlBuilder = httpUrl.newBuilder()
                                request.params.forEach { (key, value) ->
                                    val formattedValue = value
                                        .replace("{full_phone}", phone.toString())
                                        .replace("{phone}", phone.phone)
                                        .replace("{country_code}", phone.countryCode.toString())
                                        .replace("{random_uuid}", java.util.UUID.randomUUID().toString())
                                        .replace("{csrf_token}", "dummy_csrf_token")
                                        .replace("{process_uuid}", java.util.UUID.randomUUID().toString())
                                        .replace("{phone:+7 (***) ***-**-**}", phone.format("+7 (%1\$s) %2\$s-%3\$s-%4\$s"))
                                        .replace("{phone:+7(***)***-**-**}", phone.format("+7%1\$s%2\$s-%3\$s-%4\$s"))
                                        .replace("{phone:(***)***-**-**}", phone.format("(%1\$s)%2\$s-%3\$s-%4\$s"))
                                        .replace("{phone:+7 *** ***-**-**}", phone.format("+7 %1\$s %2\$s-%3\$s-%4\$s"))
                                        .replace("{phone:+7(***)***-****}", phone.format("+7%1\$s%2\$s-%3\$s%4\$s"))
                                        .replace("{phone:+7(***)***-**-**}", phone.format("+7%1\$s%2\$s-%3\$s-%4\$s"))
                                        .replace("{phone:+7 (***) ***-**-**}", phone.format("+7 (%1\$s) %2\$s-**-**"))
                                        .replace("{phone:+7(***) ***-**-**}", phone.format("+7%1\$s ***-**-**"))

                                    httpUrlBuilder.addQueryParameter(key, formattedValue)
                                }
                                urlWithParams = httpUrlBuilder.build().toString()
                            }
                        } catch (e: Exception) {
                            // If URL parsing fails, continue with original URL
                            e.printStackTrace()
                        }
                    }

                    val requestBuilder = Request.Builder().url(urlWithParams)

                    // Set HTTP method and body
                    when (request.method.uppercase()) {
                        "GET" -> requestBuilder.get()
                        "POST" -> {
                            val body = createRequestBody(request, phone)
                            requestBuilder.post(body)
                        }
                        "PUT" -> {
                            val body = createRequestBody(request, phone)
                            requestBuilder.put(body)
                        }
                        "DELETE" -> {
                            val body = createRequestBody(request, phone)
                            requestBuilder.delete(body)
                        }
                        "PATCH" -> {
                            val body = createRequestBody(request, phone)
                            requestBuilder.patch(body)
                        }
                        else -> {
                            val body = createRequestBody(request, phone)
                            requestBuilder.method(request.method.uppercase(), body)
                        }
                    }

                    // Add headers
                    request.headers?.forEach { (key, value) ->
                        val formattedValue = value
                            .replace("{full_phone}", phone.toString())
                            .replace("{phone}", phone.phone)
                            .replace("{country_code}", phone.countryCode.toString())
                            .replace("{random_uuid}", java.util.UUID.randomUUID().toString())
                            .replace("{csrf_token}", "dummy_csrf_token")
                            .replace("{process_uuid}", java.util.UUID.randomUUID().toString())
                            .replace("{phone:+7 (***) ***-**-**}", phone.format("+7 (%1\$s) %2\$s-%3\$s-%4\$s"))
                            .replace("{phone:+7(***)***-**-**}", phone.format("+7%1\$s%2\$s-%3\$s-%4\$s"))
                            .replace("{phone:(***)***-**-**}", phone.format("(%1\$s)%2\$s-%3\$s-%4\$s"))
                            .replace("{phone:+7 *** ***-**-**}", phone.format("+7 %1\$s %2\$s-%3\$s-%4\$s"))
                            .replace("{phone:+7(***)***-****}", phone.format("+7%1\$s%2\$s-%3\$s%4\$s"))
                            .replace("{phone:+7(***)***-**-**}", phone.format("+7%1\$s%2\$s-%3\$s-%4\$s"))
                            .replace("{phone:+7 (***) ***-**-**}", phone.format("+7 (%1\$s) %2\$s-**-**"))
                            .replace("{phone:+7(***) ***-**-**}", phone.format("+7%1\$s ***-**-**"))

                        requestBuilder.addHeader(key, formattedValue)
                    }

                    val httpRequest = requestBuilder.build()

                    client.newCall(httpRequest).enqueue(object : okhttp3.Callback {
                        override fun onFailure(call: Call, e: IOException) {
                            callback.onError(call, e)
                        }

                        override fun onResponse(call: Call, response: okhttp3.Response) {
                            response.close() // Close response to free resources
                            callback.onResponse(call, response)
                        }
                    })
                }
            }
        }

        private fun createRequestBody(request: ServiceRequest, phone: Phone): RequestBody {
            return when {
                request.data != null -> {
                    // Form data
                    val formBuilder = FormBody.Builder()
                    request.data.forEach { (key, value) ->
                        val formattedValue = value
                            .replace("{full_phone}", phone.toString())
                            .replace("{phone}", phone.phone)
                            .replace("{country_code}", phone.countryCode.toString())
                            .replace("{random_uuid}", java.util.UUID.randomUUID().toString())
                            .replace("{csrf_token}", "dummy_csrf_token")
                            .replace("{process_uuid}", java.util.UUID.randomUUID().toString())
                            .replace("{phone:+7 (***) ***-**-**}", phone.format("+7 (%1\$s) %2\$s-%3\$s-%4\$s"))
                            .replace("{phone:+7(***)***-**-**}", phone.format("+7%1\$s%2\$s-%3\$s-%4\$s"))
                            .replace("{phone:(***)***-**-**}", phone.format("(%1\$s)%2\$s-%3\$s-%4\$s"))
                            .replace("{phone:+7 *** ***-**-**}", phone.format("+7 %1\$s %2\$s-%3\$s-%4\$s"))
                            .replace("{phone:+7(***)***-****}", phone.format("+7%1\$s%2\$s-%3\$s%4\$s"))
                            .replace("{phone:+7(***)***-**-**}", phone.format("+7%1\$s%2\$s-%3\$s-%4\$s"))
                            .replace("{phone:+7 (***) ***-**-**}", phone.format("+7 (%1\$s) %2\$s-**-**"))
                            .replace("{phone:+7(***) ***-**-**}", phone.format("+7%1\$s ***-**-**"))
                        
                        formBuilder.add(key, formattedValue)
                    }
                    formBuilder.build()
                }
                else -> {
                    // Empty body
                    "".toRequestBody("application/json".toMediaType())
                }
            }
        }
    }
}